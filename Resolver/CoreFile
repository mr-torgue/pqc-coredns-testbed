. {
    resolver {
        hints "named.test.root"
        anchor "root-anchors.test.xml"
        clientType "udp"
        nofallback
    }
}

quic://.:853 {
    tls cert.pem key.pem
    quic {
        max_streams 16
        worker_pool_size 65536
    }
    resolver {
        hints "named.test.root"
        anchor "root-anchors.test.xml"
        clientType "doq"
        nofallback
    }
}