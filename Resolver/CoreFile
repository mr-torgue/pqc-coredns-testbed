. {
    errors
    log
    debug
    resolver {
        hints "named.test.root"
        anchor "trust-anchors.xml"
        clientType "udp"
        nofallback
    }
}

quic://.:853 {
    errors
    log
    debug
    tls /opt/coredns/cert.pem /opt/coredns/key.pem
    quic {
        max_streams 16
        worker_pool_size 65536
    }
    resolver {
        hints "named.test.root"
        anchor "root-anchors.test.xml"
        clientType "doq"
        nofallback
    }
}