$ORIGIN .
$TTL    604800
.       IN      SOA      ns1.root. hostmaster.root. (
                  3       ; Serial
             604800     ; Refresh
              86400     ; Retry
            2419200     ; Expire
             604800 )   ; Negative Cache TTL
;
; name servers - NS records
.     IN      NS      ns1.root.

; name servers - A records
ns1.root.	IN      A      192.168.121.100

local.	IN	NS	ns1.local.
ns1.local.	IN	A	1.2.3.4

test. IN A 1.1.1.1
test2. IN A 2.2.2.2