$TTL    604800
@               IN              SOA             ns1.example.test. hostmaster.example.test. (
                                                                                                                            6    ; Serial
                                                                                                                            604800       ; Refresh
                                                                                                                            86400        ; Retry
                                                                                                                            2419200      ; Expire
                                                                                                                            604800 )     ; Negative Cache TTL
; name servers - NS records
